return {
  "ThePrimeagen/harpoon",
  branch = "harpoon2",
  opts = {
    menu = {
      width = vim.api.nvim_win_get_width(0) - 4,
    },
    settings = {
      save_on_toggle = true,
    },
  },
  keys = function()
    local keys = {
      {
        "<leader>A",
        function()
          require("harpoon"):list():prepend()
        end,
        desc = "Harpoon File Before",
      },
      {
        "<leader>a",
        function()
          require("harpoon"):list():add()
        end,
        desc = "Harpoon File After",
      },
      {
        "<M-leader>",
        function()
          local harpoon = require("harpoon")
          harpoon.ui:toggle_quick_menu(harpoon:list())
        end,
        desc = "Harpoon Quick Menu",
      },
    }

    local mappings = {
      { "<M-h>", 1 },
      { "<M-j>", 2 },
      { "<M-k>", 3 },
      { "<M-l>", 4 },
      { "<M-;>", 5 },
    }

    local harpoon = require("harpoon")
    for _, m in ipairs(mappings) do
      table.insert(keys, {
        m[1],
        function()
          harpoon:list():select(m[2])
        end,
        desc = "Harpoon file " .. m[2],
      })
    end
    return keys
  end,
}
